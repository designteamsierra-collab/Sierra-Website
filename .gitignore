# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# next 16 generated route types
.next-types

# Phase 0 recon bulk data — regeneratable from scripts; only the report + JSON summary are tracked
docs/recon-data/pages/
docs/recon-data/rest/
docs/recon-data/psi/
docs/recon-data/_homepage.html

# Local-only env files (note: .env* already covered above)

# Local helper for env vars Claude Code uses; not needed in production
.shell-env.sh

# Per-user Claude Code state (NOT the project-level conventions)
.claude/settings.local.json

# Phase 4 lead-capture stub output (gitignored — captured leads aren't repo data)
data/

# WordPress export — one-time migration source, not part of the site
import/
